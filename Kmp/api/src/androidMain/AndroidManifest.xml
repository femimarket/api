<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <!-- Points Rust's ProjectService at filesDir at process start, before
             any app code runs — the Android counterpart of Apple/web where
             Rust resolves its own sandboxed root. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="market.femi.api.ProjectServiceInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>
